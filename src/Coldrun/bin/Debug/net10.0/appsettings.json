{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Coldrun": "Information"
    }
  },
  "AllowedHosts": "*",
  "Coldrun": {
    "RateLimiting": {
      "PermitLimit": 100,
      "WindowMinutes": 1
    },
    "HealthChecks": {
      "EnableReadinessDbCheck": false
    },
    "Modules": {
      "Trucks": {
        "Enabled": true
      }
    }
  }
}
